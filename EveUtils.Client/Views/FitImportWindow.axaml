<v:ChromedWindow xmlns="https://github.com/avaloniaui" xmlns:v="using:EveUtils.Client.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dlg="using:EveUtils.Client.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="520"
        x:Class="EveUtils.Client.Views.FitImportWindow"
        x:Name="Root"
        Width="560" Height="520"
        WindowStartupLocation="CenterOwner"
        Title="Import fittings from ESI">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="Choose fits to import" FontWeight="Bold" FontSize="15"
                       Foreground="{StaticResource TextBrightBrush}"/>
            <TextBlock Text="{Binding HeaderText, ElementName=Root}"
                       FontSize="11" Foreground="{DynamicResource TextAccentBrush}" TextWrapping="Wrap"/>
            <TextBox PlaceholderText="Search by name…" TextChanged="OnSearchChanged" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,12,0,0">
            <Button Content="Select all" Click="OnSelectAll"/>
            <Button Content="Select none" Click="OnSelectNone"/>
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Content="Import selected" Click="OnConfirm" Classes="accent"/>
        </StackPanel>

        <Border Classes="panel">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding VisibleChoices, ElementName=Root}" Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dlg:FitChoiceViewModel">
                            <Border Margin="0,0,0,6" Padding="8" Background="#14FFFFFF" CornerRadius="3">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrightBrush}"/>
                                        <TextBlock Text="{Binding ShipTypeId, StringFormat='ship type: {}{0}'}"
                                                   FontSize="10" Foreground="{DynamicResource TextAccentBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding ItemCount, StringFormat='{}{0} slots'}"
                                               FontSize="10" VerticalAlignment="Center" Opacity="0.75"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</v:ChromedWindow>
