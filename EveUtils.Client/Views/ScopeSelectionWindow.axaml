<v:ChromedWindow xmlns="https://github.com/avaloniaui" xmlns:v="using:EveUtils.Client.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dlg="using:EveUtils.Client.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="480"
        x:Class="EveUtils.Client.Views.ScopeSelectionWindow"
        x:Name="Root"
        Width="560" Height="480"
        WindowStartupLocation="CenterOwner"
        Title="Select ESI scopes">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="Which access do you want to grant?" FontWeight="Bold" FontSize="15"
                       Foreground="{StaticResource TextBrightBrush}"/>
            <TextBlock Text="Pick the scopes to request from EVE. You can re-authenticate later to add more."
                       FontSize="11" Foreground="{DynamicResource TextAccentBrush}" TextWrapping="Wrap"/>
            <TextBlock Text="publicData is always included (required for sign-in)." FontSize="10"
                       Opacity="0.7" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,12,0,0">
            <Button Content="Select all" Click="OnSelectAll"/>
            <Button Content="Select none" Click="OnSelectNone"/>
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Content="Sign in →" Click="OnConfirm" Classes="accent"/>
        </StackPanel>

        <Border Classes="panel">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Choices, ElementName=Root}" Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dlg:ScopeChoiceViewModel">
                            <Border Margin="0,0,0,6" Padding="8" Background="#14FFFFFF" CornerRadius="3">
                                <Grid ColumnDefinitions="Auto,*">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Top" Margin="0,2,0,0"/>
                                    <StackPanel Grid.Column="1" Spacing="2" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding Feature}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrightBrush}"/>
                                        <TextBlock Text="{Binding Scope}" FontSize="10" FontFamily="monospace"
                                                   Foreground="{DynamicResource TextAccentBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   TextWrapping="Wrap" Opacity="0.85"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</v:ChromedWindow>
