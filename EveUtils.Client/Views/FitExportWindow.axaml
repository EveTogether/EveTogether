<v:ChromedWindow xmlns="https://github.com/avaloniaui" xmlns:v="using:EveUtils.Client.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="480"
        x:Class="EveUtils.Client.Views.FitExportWindow"
        Width="560" Height="500" MinWidth="420" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Title="Export fit">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10">
            <TextBlock x:Name="TitleBlock" FontWeight="Bold" FontSize="14"
                       Foreground="{StaticResource TextBrightBrush}"/>
            <TextBlock Text="Copy the fit as EFT, DNA or an eveship.fit link to share it (paste into pyfa, the game, or a browser)."
                       FontSize="11" Foreground="{DynamicResource TextAccentBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Click="OnClose" MinWidth="80"/>
        </StackPanel>

        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="0">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <TextBlock Grid.Column="0" Text="EFT" Classes="label" FontSize="9" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Copy EFT" Click="OnCopyEft"/>
            </Grid>
            <TextBox Grid.Row="1" x:Name="EftBox" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="NoWrap" FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                     VerticalContentAlignment="Top"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,10,0,4">
                <TextBlock Grid.Column="0" Text="DNA" Classes="label" FontSize="9" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Copy DNA" Click="OnCopyDna"/>
            </Grid>
            <TextBox Grid.Row="3" x:Name="DnaBox" IsReadOnly="True" AcceptsReturn="False"
                     TextWrapping="Wrap" FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                     MaxHeight="60" ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,10,0,4">
                <TextBlock Grid.Column="0" Text="EVESHIP.FIT LINK" Classes="label" FontSize="9" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Copy link" Click="OnCopyEveship"/>
            </Grid>
            <TextBox Grid.Row="5" x:Name="EveshipBox" IsReadOnly="True" AcceptsReturn="False"
                     TextWrapping="Wrap" FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                     MaxHeight="60" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </DockPanel>
</v:ChromedWindow>
