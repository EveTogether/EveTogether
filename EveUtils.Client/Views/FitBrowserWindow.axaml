<v:ChromedWindow xmlns="https://github.com/avaloniaui" xmlns:v="using:EveUtils.Client.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fb="using:EveUtils.Client.ViewModels.FitBrowser"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="660"
        x:Class="EveUtils.Client.Views.FitBrowserWindow"
        x:DataType="fb:FitBrowserViewModel"
        Width="1100" Height="660"
        WindowStartupLocation="CenterOwner"
        Title="Fit Browser">

    <DockPanel Margin="16">

        <!-- Header: title + import actions (the browser is the single fittings surface, D-182 review) -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Spacing="3">
                <TextBlock Text="FIT BROWSER" FontWeight="Bold" FontSize="16"
                           Foreground="{StaticResource TextBrightBrush}"/>
                <TextBlock Text="Browse your Local library and each coupled server's shared fits (D-108). Double-click a fit for the full radial view + stats."
                           FontSize="11" Foreground="{DynamicResource TextAccentBrush}" TextWrapping="Wrap" MaxWidth="700"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top"
                        IsVisible="{Binding CanImport}">
                <!-- Single import dropdown (D-188 FBX-6): same Button+MenuFlyout pattern + theming as the export menu -->
                <Button Content="IMPORT ▾" ToolTip.Tip="Import a fit from EVE, EFT/DNA text or an eveship.fit link">
                    <Button.Flyout>
                        <MenuFlyout>
                            <TextBlock Classes="menuHeader" Text="IMPORT FIT" IsHitTestVisible="False"/>
                            <MenuItem Header="From EVE (ESI)…" Command="{Binding ImportFromEsiCommand}"
                                      ToolTip.Tip="Fetch your fits from EVE and pick which to import. Choose the character in the dialog (D-90).">
                                <MenuItem.Icon><TextBlock Text="⤓" FontSize="13"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="From EFT / DNA text…" Command="{Binding ImportTextCommand}"
                                      ToolTip.Tip="Paste an EFT block or DNA string to import a fit (D-47).">
                                <MenuItem.Icon><TextBlock Text="▤" FontSize="13"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="From ESF link…" Command="{Binding ImportEsfLinkCommand}"
                                      ToolTip.Tip="Paste an eveship.fit link to import a fit (D-188).">
                                <MenuItem.Icon><TextBlock Text="🔗" FontSize="13"/></MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <Button Grid.Column="1" Content="Close" Click="OnClose" Classes="accent"/>
        </Grid>

        <TabControl ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}">
            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="fb:FitBrowserTabViewModel">
                    <TextBlock Text="{Binding Header}" FontSize="11"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate x:DataType="fb:FitBrowserTabViewModel">
                    <DockPanel Margin="0,8,0,0">

                        <!-- Search + page-size -->
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,6">
                            <TextBox Grid.Column="0" Text="{Binding Search}" PlaceholderText="Search by name or tag…"
                                     VerticalContentAlignment="Center" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="Per page" VerticalAlignment="Center"
                                       Margin="10,0,6,0" FontSize="11" Foreground="{DynamicResource TextAccentBrush}"/>
                            <ComboBox Grid.Column="2" MinWidth="70"
                                      ItemsSource="{x:Static fb:FitBrowserTabViewModel.PageSizeOptions}"
                                      SelectedItem="{Binding PageSize}"/>
                        </Grid>

                        <!-- Status line (server tabs: loading / empty) -->
                        <TextBlock DockPanel.Dock="Top" Text="{Binding Status}" FontSize="10"
                                   Margin="2,0,2,6" Foreground="{DynamicResource TextAccentBrush}"
                                   IsVisible="{Binding !IsLocal}"/>

                        <!-- Pager -->
                        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,8,0,0">
                            <Button Grid.Column="0" Content="⏮" FontSize="11" Command="{Binding FirstPageCommand}"
                                    IsEnabled="{Binding CanPrev}" ToolTip.Tip="First page"/>
                            <Button Grid.Column="1" Content="◀" FontSize="11" Margin="4,0,0,0" Command="{Binding PrevPageCommand}"
                                    IsEnabled="{Binding CanPrev}" ToolTip.Tip="Previous page"/>
                            <TextBlock Grid.Column="2" Text="{Binding PageInfo}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextAccentBrush}"/>
                            <Button Grid.Column="3" Content="▶" FontSize="11" Margin="0,0,4,0" Command="{Binding NextPageCommand}"
                                    IsEnabled="{Binding CanNext}" ToolTip.Tip="Next page"/>
                            <Button Grid.Column="4" Content="⏭" FontSize="11" Command="{Binding LastPageCommand}"
                                    IsEnabled="{Binding CanNext}" ToolTip.Tip="Last page"/>
                        </Grid>

                        <!-- Full-width fit table (D-188 FBX-4): hull · fit name · slot counts (+ tooltip) · uploader · export -->
                        <Panel>
                            <TextBlock Text="No fits here yet." IsVisible="{Binding IsEmpty}"
                                       Foreground="{DynamicResource TextAccentBrush}" Margin="2,8"/>
                            <DataGrid x:CompileBindings="False"
                                      IsVisible="{Binding !IsEmpty}"
                                      ItemsSource="{Binding PagedRows}"
                                      SelectedItem="{Binding SelectedRow}"
                                      DoubleTapped="OnRowDoubleTapped"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single"
                                      CanUserReorderColumns="False" CanUserResizeColumns="True"
                                      CanUserSortColumns="True">
                                <DataGrid.Columns>

                                    <!-- Hull: round render + name -->
                                    <DataGridTemplateColumn Header="HULL" Width="210" CanUserSort="True" SortMemberPath="ShipTypeLabel">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="0,3">
                                                    <Border Width="32" Height="32" CornerRadius="16" ClipToBounds="True"
                                                            Background="#12FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                        <Image Source="{Binding HullImage}" IsVisible="{Binding HasHullImage}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding ShipTypeLabel}" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextBrightBrush}" FontWeight="SemiBold"/>
                                                    <!-- Hull class (e.g. "Frigate") from the SDE group, hidden until resolved (D-188) -->
                                                    <TextBlock Text="{Binding HullClass}" IsVisible="{Binding HasHullClass}"
                                                               VerticalAlignment="Center" FontSize="11"
                                                               Foreground="{DynamicResource TextDimBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Fit name -->
                                    <DataGridTextColumn Header="FIT NAME" Binding="{Binding Name}" Width="*"/>

                                    <!-- High / Medium / Low: "x modules" + per-module tooltip (icons load on hover) -->
                                    <DataGridTemplateColumn Header="HIGH" Width="105" CanUserSort="True" SortMemberPath="HighCount">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="5" Tag="High" Cursor="Hand"
                                                            VerticalAlignment="Center" HorizontalAlignment="Left"
                                                            PointerEntered="OnRackPointerEntered" ToolTip.ShowDelay="250">
                                                    <TextBlock Text="{Binding HighCount, StringFormat='{}{0} modules'}"
                                                               FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="▾" FontSize="10" Foreground="{DynamicResource TextAccentBrush}" VerticalAlignment="Center"/>
                                                    <ToolTip.Tip>
                                                        <StackPanel MinWidth="200">
                                                            <TextBlock Text="HIGH SLOTS" FontSize="9" FontWeight="SemiBold" LetterSpacing="1.4"
                                                                       Foreground="{DynamicResource TextDimBrush}" Margin="2,0,0,7"/>
                                                            <ItemsControl ItemsSource="{Binding HighModules}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="9" Margin="0,3">
                                                                            <Image Source="{Binding Image}" IsVisible="{Binding HasImage}" Width="22" Height="22"/>
                                                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextBrush}"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </ToolTip.Tip>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="MEDIUM" Width="105" CanUserSort="True" SortMemberPath="MidCount">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="5" Tag="Medium" Cursor="Hand"
                                                            VerticalAlignment="Center" HorizontalAlignment="Left"
                                                            PointerEntered="OnRackPointerEntered" ToolTip.ShowDelay="250">
                                                    <TextBlock Text="{Binding MidCount, StringFormat='{}{0} modules'}"
                                                               FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="▾" FontSize="10" Foreground="{DynamicResource TextAccentBrush}" VerticalAlignment="Center"/>
                                                    <ToolTip.Tip>
                                                        <StackPanel MinWidth="200">
                                                            <TextBlock Text="MID SLOTS" FontSize="9" FontWeight="SemiBold" LetterSpacing="1.4"
                                                                       Foreground="{DynamicResource TextDimBrush}" Margin="2,0,0,7"/>
                                                            <ItemsControl ItemsSource="{Binding MidModules}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="9" Margin="0,3">
                                                                            <Image Source="{Binding Image}" IsVisible="{Binding HasImage}" Width="22" Height="22"/>
                                                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextBrush}"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </ToolTip.Tip>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="LOW" Width="105" CanUserSort="True" SortMemberPath="LowCount">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="5" Tag="Low" Cursor="Hand"
                                                            VerticalAlignment="Center" HorizontalAlignment="Left"
                                                            PointerEntered="OnRackPointerEntered" ToolTip.ShowDelay="250">
                                                    <TextBlock Text="{Binding LowCount, StringFormat='{}{0} modules'}"
                                                               FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="▾" FontSize="10" Foreground="{DynamicResource TextAccentBrush}" VerticalAlignment="Center"/>
                                                    <ToolTip.Tip>
                                                        <StackPanel MinWidth="200">
                                                            <TextBlock Text="LOW SLOTS" FontSize="9" FontWeight="SemiBold" LetterSpacing="1.4"
                                                                       Foreground="{DynamicResource TextDimBrush}" Margin="2,0,0,7"/>
                                                            <ItemsControl ItemsSource="{Binding LowModules}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="9" Margin="0,3">
                                                                            <Image Source="{Binding Image}" IsVisible="{Binding HasImage}" Width="22" Height="22"/>
                                                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextBrush}"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </ToolTip.Tip>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Price avg. (D-188 FBX-5): summed ESI average_price over hull + items × qty -->
                                    <DataGridTemplateColumn Header="PRICE AVG." Width="120" CanUserSort="True" SortMemberPath="Price">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PriceLabel}" VerticalAlignment="Center"
                                                           HorizontalAlignment="Right" Margin="0,0,12,0" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ValueBrush}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Uploader = the sharer; only meaningful on a server tab. Local fits are all yours
                                         (and imports have no character), so the column is hidden there (D-188). -->
                                    <DataGridTextColumn Header="UPLOADER" Binding="{Binding Uploader}" Width="170"
                                                        IsVisible="{Binding !IsLocal}"/>

                                    <!-- Per-row export dropdown (same four actions + styling as the fit-detail header) -->
                                    <DataGridTemplateColumn Header="EXPORT" Width="92">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="⤓" IsVisible="{Binding CanExport}" HorizontalAlignment="Center"
                                                        Padding="9,3" FontSize="14" Foreground="{DynamicResource TextAccentBrush}"
                                                        ToolTip.Tip="Export this fit">
                                                    <Button.Flyout>
                                                        <MenuFlyout>
                                                            <TextBlock Classes="menuHeader" Text="EXPORT FIT" IsHitTestVisible="False"/>
                                                            <MenuItem Header="Share to server…" Command="{Binding ShareToServerCommand}">
                                                                <MenuItem.Icon><TextBlock Text="☁" FontSize="13"/></MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Push to EVE (in-game)…" Command="{Binding PushToEveCommand}">
                                                                <MenuItem.Icon><TextBlock Text="⏵" FontSize="13"/></MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator/>
                                                            <MenuItem Header="Copy eveship.fit link" Command="{Binding CopyEveshipLinkCommand}">
                                                                <MenuItem.Icon><TextBlock Text="🔗" FontSize="13"/></MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Open EFT window…" Command="{Binding OpenEftWindowCommand}">
                                                                <MenuItem.Icon><TextBlock Text="▤" FontSize="13"/></MenuItem.Icon>
                                                            </MenuItem>
                                                        </MenuFlyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Manage (fit-metadata): edit name/tags/description + delete, on local fits only -->
                                    <DataGridTemplateColumn Header="" Width="48">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="⋯" IsVisible="{Binding CanManage}" HorizontalAlignment="Center"
                                                        Padding="9,3" FontSize="14" Foreground="{DynamicResource TextAccentBrush}"
                                                        ToolTip.Tip="Manage this fit">
                                                    <Button.Flyout>
                                                        <MenuFlyout>
                                                            <TextBlock Classes="menuHeader" Text="FIT" IsHitTestVisible="False"/>
                                                            <MenuItem Header="Edit details…" Command="{Binding EditMetadataCommand}">
                                                                <MenuItem.Icon><TextBlock Text="✎" FontSize="13"/></MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator/>
                                                            <MenuItem Header="Delete" Command="{Binding DeleteCommand}">
                                                                <MenuItem.Icon><TextBlock Text="🗑" FontSize="13"/></MenuItem.Icon>
                                                            </MenuItem>
                                                        </MenuFlyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </Panel>
                    </DockPanel>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</v:ChromedWindow>
