<v:ChromedWindow xmlns="https://github.com/avaloniaui" xmlns:v="using:EveUtils.Client.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EveUtils.Client.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="580"
        x:Class="EveUtils.Client.Views.FitPickerWindow"
        x:DataType="vm:FitPickerViewModel"
        x:Name="FitPickerRoot"
        Width="560" Height="580" MinWidth="480" MinHeight="420" CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="SELECT A FIT">

    <v:ChromedWindow.Styles>
        <Style Selector="Button.srctab">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.srctab.active">
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.fitrow">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style Selector="Button.fitrow:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style Selector="Border.fitcard.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
        </Style>
        <Style Selector="Border.checkbox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style Selector="Border.checkbox.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
        </Style>
    </v:ChromedWindow.Styles>

    <v:ChromedWindow.Resources>
        <!-- one row template, shared by the flat (Local/Server) and grouped (Composition) lists -->
        <DataTemplate x:Key="FitRow" x:DataType="vm:FitPickerRowViewModel">
            <Button Classes="fitrow" IsEnabled="{Binding !AlreadyAdded}"
                    Command="{Binding #FitPickerRoot.((vm:FitPickerViewModel)DataContext).ActivateRowCommand}"
                    CommandParameter="{Binding}">
                <Border Classes="fitcard" Classes.selected="{Binding IsSelected}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Background="#08FFFFFF" Padding="9,7">
                    <Grid ColumnDefinitions="Auto,10,*,Auto,Auto">
                        <Border Grid.Column="0" Width="24" Height="28" CornerRadius="3" ClipToBounds="True"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Image Source="{Binding HullImage}" IsVisible="{Binding HasHullImage}" Stretch="Uniform"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding FitName}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrightBrush}"/>
                                <TextBlock Text="✓" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource TextAccentBrush}"
                                           IsVisible="{Binding CanFly}" ToolTip.Tip="{Binding SkillBadgeTooltip}"/>
                                <TextBlock Text="⚠" FontSize="11" VerticalAlignment="Center" Foreground="#E0B341"
                                           IsVisible="{Binding HasSkillGap}" ToolTip.Tip="{Binding SkillBadgeTooltip}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Detail}" Classes="label" FontSize="9"/>
                        </StackPanel>
                        <Button Grid.Column="3" Content="DETAIL" FontSize="8" Classes="accent" Margin="0,0,8,0"
                                VerticalAlignment="Center" ToolTip.Tip="Open fit detail"
                                Command="{Binding #FitPickerRoot.((vm:FitPickerViewModel)DataContext).OpenDetailCommand}"
                                CommandParameter="{Binding}"/>
                        <!-- multi: checkbox -->
                        <Border Grid.Column="4" Classes="checkbox" Classes.selected="{Binding IsSelected}"
                                Width="20" Height="20" CornerRadius="3" VerticalAlignment="Center" BorderThickness="1"
                                IsVisible="{Binding #FitPickerRoot.((vm:FitPickerViewModel)DataContext).IsMulti}">
                            <TextBlock Text="✓" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrightBrush}" IsVisible="{Binding IsSelected}"/>
                        </Border>
                        <!-- single: current marker or Select -->
                        <TextBlock Grid.Column="4" Text="✓ current" FontSize="9" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrightBrush}"
                                   IsVisible="{Binding IsCurrent}"/>
                        <Button Grid.Column="4" Content="SELECT" FontSize="9" Classes="accent" VerticalAlignment="Center"
                                Command="{Binding #FitPickerRoot.((vm:FitPickerViewModel)DataContext).ActivateRowCommand}"
                                CommandParameter="{Binding}">
                            <Button.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="#FitPickerRoot.((vm:FitPickerViewModel)DataContext).IsSingle"/>
                                    <Binding Path="!IsCurrent"/>
                                </MultiBinding>
                            </Button.IsVisible>
                        </Button>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </v:ChromedWindow.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Height="40" Background="#EA080604"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Margin="14,0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="◆" Foreground="{DynamicResource AccentBrush}" FontSize="9" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding HeaderTitle}" FontWeight="Bold" FontSize="13" LetterSpacing="2.2"
                           Foreground="{StaticResource TextBrightBrush}"/>
                <TextBlock Text="{Binding HeaderSub}" FontSize="10" LetterSpacing="1.5" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextAccentBrush}"/>
            </StackPanel>
        </Border>

        <!-- Footer (multi only) -->
        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="13,10" IsVisible="{Binding IsMulti}">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="10"
                           Text="{Binding SelectedCount, StringFormat='{}{0} selected'}"
                           Foreground="{DynamicResource TextAccentBrush}"/>
                <Button Grid.Column="1" Content="CANCEL" FontSize="11" Margin="0,0,8,0" Click="OnCancel"/>
                <Button Grid.Column="2" Content="ADD" FontSize="11" Classes="accent"
                        IsEnabled="{Binding CanConfirm}" Click="OnAdd"/>
            </Grid>
        </Border>

        <!-- Cancel bar (single only) -->
        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="13,10" IsVisible="{Binding IsSingle}">
            <Button Content="CANCEL" FontSize="11" HorizontalAlignment="Right" Click="OnCancel"/>
        </Border>

        <Grid Margin="12" RowDefinitions="Auto,10,*">

            <!-- Tools: source tabs + search -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,10,*">
                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Composition" Classes="srctab" Classes.active="{Binding IsCompositionSource}"
                                IsVisible="{Binding HasComposition}" Command="{Binding ShowCompositionCommand}"/>
                        <Button Content="Local" Classes="srctab" Classes.active="{Binding IsLocalSource}"
                                Command="{Binding ShowLocalCommand}"/>
                        <Button Content="Server" Classes="srctab" Classes.active="{Binding IsServerSource}"
                                Command="{Binding ShowServerCommand}"/>
                    </StackPanel>
                </Border>
                <TextBox Grid.Column="2" Text="{Binding SearchText}" PlaceholderText="Search fit / ship…" FontSize="11"/>
            </Grid>

            <!-- Empty state -->
            <TextBlock Grid.Row="2" Text="No fits match." IsVisible="{Binding IsEmpty}" Classes="label" FontSize="12"
                       FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Flat list (Local / Server) -->
            <ScrollViewer Grid.Row="2" IsVisible="{Binding !IsCompositionSource}">
                <ItemsControl ItemsSource="{Binding Rows}" ItemTemplate="{StaticResource FitRow}"/>
            </ScrollViewer>

            <!-- Grouped list (Composition) -->
            <ScrollViewer Grid.Row="2" IsVisible="{Binding IsCompositionSource}">
                <ItemsControl ItemsSource="{Binding RoleGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FitPickerRoleGroupViewModel">
                            <StackPanel Margin="0,0,0,8">
                                <Grid ColumnDefinitions="Auto,8,Auto,*,Auto" Margin="2,4,2,5">
                                    <Border Grid.Column="0" Width="6" Height="6" CornerRadius="2" VerticalAlignment="Center"
                                            Background="{DynamicResource AccentBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RoleName}" FontSize="10" LetterSpacing="1"
                                               Foreground="{DynamicResource TextAccentBrush}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding MinLabel}" FontSize="9" FontFamily="Consolas,monospace"
                                               Foreground="{DynamicResource TextDimBrush}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Rows}" ItemTemplate="{StaticResource FitRow}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</v:ChromedWindow>
