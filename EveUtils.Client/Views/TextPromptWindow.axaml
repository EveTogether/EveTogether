<v:ChromedWindow xmlns="https://github.com/avaloniaui" xmlns:v="using:EveUtils.Client.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="200"
        x:Class="EveUtils.Client.Views.TextPromptWindow"
        x:Name="Root"
        Width="420" SizeToContent="Height" MaxHeight="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Title="EVE Together">

    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,14,0,0">
            <Button Content="Cancel" Click="OnCancel" MinWidth="80"/>
            <Button Content="OK" Click="OnConfirm" Classes="accent" MinWidth="80"/>
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock x:Name="HeaderBlock" FontWeight="Bold" FontSize="14"
                       Foreground="{StaticResource TextBrightBrush}"/>
            <TextBox x:Name="ValueBox" VerticalContentAlignment="Center"/>
        </StackPanel>
    </DockPanel>
</v:ChromedWindow>
