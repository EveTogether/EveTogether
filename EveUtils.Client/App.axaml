<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveUtils.Client.App"
             xmlns:local="using:EveUtils.Client"
             xmlns:views="using:EveUtils.Client.Views"
             xmlns:fb="using:EveUtils.Client.ViewModels.FitBrowser"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <!-- Per-module fit tooltip (D-178): global so the ToolTip popup (a separate popup root) picks it up — the
             in-game module readout: name, charge, derived lines, a colour-coded damage breakdown (DEFENSE resist
             colours) and a state line coloured by the module's state. Placed before the ViewLocator so it matches first. -->
        <DataTemplate DataType="fb:ModuleTooltipViewModel" x:DataType="fb:ModuleTooltipViewModel">
            <Border Background="#F5121A22" CornerRadius="4" Padding="9,7" MaxWidth="340">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding SlotLabel}" IsVisible="{Binding HasSlotLabel}" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextAccentBrush}"/>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextBrightBrush}"/>
                    <TextBlock Text="{Binding ChargeName}" IsVisible="{Binding HasCharge}" FontSize="11" Foreground="{DynamicResource TextAccentBrush}"/>
                    <ItemsControl ItemsSource="{Binding Lines}" x:CompileBindings="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#C9D2DA"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding DamageSegments}" IsVisible="{Binding HasDamage}" Margin="0,1,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="8"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="fb:DamageSegmentViewModel">
                                <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding Brush}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding StateLabel, StringFormat='── {0}'}" Foreground="{Binding StateBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <!-- Faction palette (D-183): the swappable tokens (accent ramp, borders, glows, header/window gradients, hex brand)
         live in a per-faction ResourceDictionary merged here. ThemeService swaps this entry at runtime so the whole
         surface re-tints live (DynamicResource consumers update without a reload). Default = Gallente (the original
         Federation-green look). Pinning the SystemAccentColor* ramp also keeps the Fluent button states identical and
         on-theme across Windows/Linux (D-177). -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://EveUtils.Client/Themes/Factions/Gallente.axaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Recursive EVE move-cascade menu theme (Fleet → Wing → Squad). Defined globally so the nested submenu
                 popups (each a separate resource scope) can resolve the self-referencing ItemContainerTheme to any
                 depth — when it lived in the window's resources only the first level bound and deeper items fell back
                 to the view-model's ToString. Reflection bindings sidestep the compiled-binding DataType requirement. -->
            <ControlTheme x:Key="MoveMenuItemTheme" TargetType="MenuItem"
                          BasedOn="{StaticResource {x:Type MenuItem}}">
                <Setter Property="Header" Value="{ReflectionBinding Label}"/>
                <Setter Property="ItemsSource" Value="{ReflectionBinding Children}"/>
                <Setter Property="Command" Value="{ReflectionBinding Command}"/>
                <Setter Property="ItemContainerTheme" Value="{DynamicResource MoveMenuItemTheme}"/>
            </ControlTheme>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="avares://EveUtils.Client/Themes/EveUtils.axaml"/>
    </Application.Styles>
</Application>