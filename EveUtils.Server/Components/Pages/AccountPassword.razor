@page "/account/password"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Change password — EVE Together</PageTitle>

<div class="crumb">Account / <b>Change password</b></div>

<AuthorizeView Context="auth">
    @if (auth.User.HasClaim(AdminClaims.MustChangePassword, "true"))
    {
        <p class="stale">You must change your password before continuing.</p>
    }
</AuthorizeView>

@switch (Error)
{
    case "current": <p class="stale">Current password is incorrect.</p>; break;
    case "length": <p class="stale">New password must be at least 8 characters.</p>; break;
    case "confirm": <p class="stale">New password and confirmation do not match.</p>; break;
    case "same": <p class="stale">New password must differ from the current one.</p>; break;
}

<div class="pwform">
    <Card Title="Change password" Pad="true">
        <form method="post" action="/account/password">
            <AntiforgeryToken />
            <div class="field"><label for="current">Current password</label>
                <input id="current" name="current" type="password" autocomplete="current-password" /></div>
            <div class="field"><label for="newPassword">New password (min 8)</label>
                <input id="newPassword" name="newPassword" type="password" autocomplete="new-password" /></div>
            <div class="field"><label for="confirm">Confirm new password</label>
                <input id="confirm" name="confirm" type="password" autocomplete="new-password" /></div>
            <button type="submit" class="accent">Change password</button>
        </form>
    </Card>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}
